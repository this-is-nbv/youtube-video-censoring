{
  "manifest_version": 3,
  "name": "YouTube Profanity Censor",
  "version": "1.0",

  "permissions": [
    "activeTab"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
